# Скопируй в .env и заполни
DATABASE_URL=sqlite:///./smm.db

# Ключ для шифрования токенов соц-аккаунтов в БД (Fernet key).
# Сгенерировать: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_ENCRYPTION_KEY=

# Ключ для подписи JWT (любая длинная случайная строка)
JWT_SECRET=change-me-to-a-long-random-string

# Как часто воркер проверяет, не пора ли публиковать (секунды)
SCHEDULER_INTERVAL_SECONDS=30

# Instagram OAuth (бесплатно), новый флоу «Instagram API with Instagram Login».
# Создай приложение на developers.facebook.com -> добавь продукт Instagram ->
# «API setup with Instagram login» -> возьми Instagram App ID и Secret оттуда.
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
# Этот redirect добавь в Instagram -> Business login settings -> OAuth Redirect URIs:
META_REDIRECT_URI=http://localhost:8000/api/instagram/oauth/callback
FRONTEND_URL=http://localhost:5173
